GPU_MONITOR_DATABASE_URL=postgresql+psycopg://gpu_monitor:change_me@127.0.0.1:5432/gpu_monitor
GPU_MONITOR_API_HOST=0.0.0.0
GPU_MONITOR_API_PORT=8001
GPU_MONITOR_CLUSTER_NAME=lumia
GPU_MONITOR_MINUTE_RETENTION_DAYS=7
GPU_MONITOR_HOURLY_RETENTION_DAYS=30
GPU_MONITOR_WORKER_INTERVAL_SECONDS=60
GPU_MONITOR_DB_POOL_SIZE=20
GPU_MONITOR_DB_MAX_OVERFLOW=40
GPU_MONITOR_DB_POOL_TIMEOUT_SECONDS=30
GPU_MONITOR_DB_POOL_RECYCLE_SECONDS=1800
GPU_MONITOR_SLURM_RECONCILE_ENABLED=true
GPU_MONITOR_SLURM_RECONCILE_INTERVAL_SECONDS=300
GPU_MONITOR_SLURM_ACTIVE_JOBS_COMMAND=squeue -h -o %A
GPU_MONITOR_SLURM_COMMAND_TIMEOUT_SECONDS=15
