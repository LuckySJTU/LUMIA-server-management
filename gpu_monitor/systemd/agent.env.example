GPU_MONITOR_CLUSTER_NAME=lumia
GPU_MONITOR_API_BASE_URL=http://<controller-ip>:8001
GPU_MONITOR_NODE_DB=/var/lib/gpu-monitor/node-agent.db
GPU_MONITOR_TASK_EVENT_DIR=/var/lib/gpu-monitor/events
GPU_MONITOR_SAMPLE_INTERVAL_SECONDS=15
GPU_MONITOR_FLUSH_INTERVAL_SECONDS=60
GPU_MONITOR_HEARTBEAT_INTERVAL_SECONDS=300
GPU_MONITOR_MAPPING_STALE_MINUTES=10
GPU_MONITOR_UNDELIVERED_RETENTION_HOURS=24
GPU_MONITOR_UNDELIVERED_MAX_RECORDS=100000
GPU_MONITOR_UPLOAD_BATCH_LIMIT=2000
GPU_MONITOR_VERIFY_TLS=false
GPU_MONITOR_REQUEST_TIMEOUT_SECONDS=15
GPU_MONITOR_NODE_SLURM_RECONCILE_ENABLED=true
GPU_MONITOR_NODE_SLURM_RECONCILE_INTERVAL_SECONDS=300
GPU_MONITOR_NODE_SLURM_ACTIVE_JOBS_COMMAND=squeue -h -w {node_name} -o %A
GPU_MONITOR_NODE_SLURM_COMMAND_TIMEOUT_SECONDS=15
